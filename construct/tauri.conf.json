{
  "build": {
    "distDir": "dist",
    "devPath": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "package": {
    "productName": "NETOS",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.arasaka.netos",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "NET/OS v1.0",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": true,
        "decorations": false,
        "transparent": false
      }
    ]
  }
}
